{
  "compilerOptions": {
    "target": "es2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,

    "rootDir": "..",
    "outDir": "../build/test",
    "declaration": false
  },
  "include": ["./**/*", "../src/**/*"]
}
