{
  "name": "pg-seed-kit",
  "version": "0.0.1",
  "description": "A lightweight, zero-dependency seeder toolkit for Postgres that works with Prisma, Drizzle, TypeORM, and Sequelize.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**",
    "bin/**"
  ],
  "scripts": {
    "build": "tsup",
    "pretest": "tsc -p tests && node scripts/write-build-cjs.mjs",
    "test": "mocha",
    "lint": "eslint .",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prepare": "husky",
    "prepack": "npm run build",
    "release": "bash scripts/release.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kulcsarrudolf/pg-seed-kit.git"
  },
  "keywords": [
    "postgres",
    "postgresql",
    "seeder",
    "seed",
    "database",
    "prisma",
    "drizzle",
    "typeorm",
    "sequelize",
    "orm",
    "migration",
    "toolkit"
  ],
  "author": "Kulcsár Rudolf",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kulcsarrudolf/pg-seed-kit/issues"
  },
  "homepage": "https://kulcsarrudolf.github.io/pg-seed-kit/",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.ts": "prettier --write"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "chai": "^4.5.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mocha": "^11.7.6",
    "pg": "^8.22.0",
    "prettier": "^3.9.5",
    "testcontainers": "^12.0.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
